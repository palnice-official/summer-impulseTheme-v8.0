{% comment %} {% assign has_inventory = false %}
{% for variant in product.variants %}
  {% if variant.inventory_quantity > 0 %}
    {% assign has_inventory = true %}
    {% break %}
  {% endif %}
{% endfor %} {% endcomment %}
{% assign base_date = 'now' | date: '%s' %}
{% assign two_days_in_seconds = 2 | times: 24 | times: 60 | times: 60 %}
{% assign thirty_days_in_seconds = 28 | times: 24 | times: 60 | times: 60 %}

{% assign future_date_seconds = base_date | plus: two_days_in_seconds %}
{% assign future_date_thirty_seconds = base_date | plus: thirty_days_in_seconds %}

{% assign future_date_two = future_date_seconds | date: '%B %d, %Y' %}
{% assign future_date_thirty = future_date_thirty_seconds | date: '%B %d, %Y' %}

<div
  class="shipping_info"
  id="shipping_info"
  data-ship2= "{{future_date_two}}"
  data-ship30= "{{future_date_thirty}}"
>
  {% comment %} Loader {% endcomment %}

  <div id="shipping_loader" class="shiping_loader" hidden>
    <div class="spinner"></div>
  </div>

  {% comment %} Message {% endcomment %}
   <div id ="shipping_text"></div>
  {% comment %} <span id="shipping_text"></span> {% endcomment %}
</div>

{% comment %}
  <div class="shipping-info">
    {% if has_inventory %}
      <div class="info-wraper-1">
        <!-- <div class="bolt-info">{% render 'bolt' %}</div> -->
        {% render 'bolt' %}
        <span>Ready to Ship: Product will be Shipped by {{ future_date_two }}</span>
      </div>
    {% else %}
      <span>Product will be Shipped by {{ future_date_thirty }}</span>
    {% endif %}
  </div>


  {% style %}
    .shipping_text{
      display: block;
    }
    .shipping_text svg{
          width: 21px;
      position: relative;
      top: 6px;
      left: 3px;
    }
  {% endstyle %}
{% endcomment %}


{% comment %} <style>
  .shipping_info {
    margin-top: 10px;
    font-weight: 600;
    font-size: 14px;
    min-height: 22px;
  }

  .shiping_loader {
    opacity: 0.6;
    font-size: 13px;
  }
  .shiping_loader::after {
    content: '⏳';
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0.3;
    }
  }
</style> {% endcomment %}

<style>
  .shipping-info {
  margin-top: 10px;
  font-weight: 600;
  font-size: 14px;
  min-height: 24px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Loader wrapper */
.shipping-loader {
  display: flex;
  align-items: center;
}

/* Circular spinner */
.spinner {
  width: 16px;
  height: 16px;
  border: 2px solid #e5e5e5;
  border-top: 2px solid #000;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

/* Animation */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

</style>
