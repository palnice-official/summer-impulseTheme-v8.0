{% style %}
  .discount-box {
    margin-top: 15px;
    padding: 15px;
    border: 1px dashed #000;
    text-align: center;
  }
{% endstyle %}

{%- assign newsletter_form_id = 'newsletter-' | append: section_id -%}

{% comment %} {% form 'contact', id: newsletter_form_id %}
  {%- if form.posted_successfully? -%}
    <div class="note note--success">
      <p>🎉 Thanks for signing up!</p>

      <div class="discount-box">
        <p>Your Discount Code</p>
        <strong id="discountCode">WELCOME10</strong>
        <button type="button" onclick="copyDiscount()">Copy Code</button>
      </div>
    </div>
  {%- endif -%}

  {%- if form.errors and form.context == snippet_context -%}
    {{ form.errors | default_errors }}
  {%- endif -%}

  {%- unless form.posted_successfully? -%}
    <input type="hidden" name="contact[tags]" value="popup-lead,newsletter">
    <input type="hidden" name="contact[context]" value="{{ snippet_context }}">

    <div class="input-group newsletter__input-group">
      <input
        type="text"
        name="contact[first_name]"
        placeholder="Your Name"
        class="input-group-field newsletter__input"
        required
      >

      <input
        type="tel"
        name="contact[phone]"
        placeholder="Phone Number"
        class="input-group-field newsletter__input"
        required
      >

      <input
        type="email"
        placeholder="Your Email"
        name="contact[email]"
        id="Email-{{ section_id }}"
        class="input-group-field newsletter__input"
        autocorrect="off"
        autocapitalize="off"
        required
      >

      <div class="input-group-btn">
        <button type="submit" class="btn" name="commit">Get Discount</button>
      </div>
    </div>
  {%- endunless -%}
{% endform %} {% endcomment %}
<form id="newsletterPopupForm">
  <input type="text" name="contact[name]" placeholder="Name" required>
  <input type="tel" name="contact[phone]" placeholder="Phone" required>
  <input type="email" name="contact[email]" placeholder="Email" required>

  <input type="hidden" name="contact[tags]" value="popup-newsletter">

  <button type="submit">Get Discount</button>
</form>

<div id="discountBox" style="display:none">
  <p>Your Discount Code</p>
  <strong id="discountCode">WELCOME10</strong>
  <button onclick="copyDiscount()">Copy</button>
</div>

<script>
document.getElementById("newsletterPopupForm").addEventListener("submit", function(e) {
  e.preventDefault(); // 🚨 stops redirect

  const formData = new FormData(this);

  fetch("/customer", {
    method: "POST",
    body: formData,
    headers: {
      "Accept": "application/json"
    }
  })
  .then(() => {
    document.getElementById("newsletterPopupForm").style.display = "none";
    document.getElementById("discountBox").style.display = "block";
    localStorage.setItem("popupSubmitted", "true");
  })
  .catch(() => alert("Something went wrong"));
});

function copyDiscount() {
  navigator.clipboard.writeText("WELCOME10");
  alert("Discount code copied!");
}
</script>


{% comment %} <script>
  function copyDiscount() {
    const code = document.getElementById('discountCode').innerText;
    navigator.clipboard.writeText(code).then(() => {
      alert('Discount code copied!');
    });
  }
</script> {% endcomment %}
