{%- liquid
  comment
    ── CONFIGURE YOUR OFFERS HERE ──────────────────────────────
    Each entry: label (on wheel) | code (shown to customer) | color
    Use any valid CSS color string for the wheel slice.
    You can have 2–12 entries.
  endcomment

  assign sw_heading    = "Spin & Win!"
  assign sw_subtext    = "One spin per visit. Good luck!"
  assign sw_btn_label  = "SPIN"
  assign sw_tab_label  = "Spin & Win"

-%}

{% comment %} ── Floating launcher tab ── {% endcomment %}
<div id="sw-launcher" class="sw-launcher" role="button" tabindex="0" aria-label="Open spin the wheel">
  <span class="sw-launcher__icon">{{ sw_tab_label }}</span>
  <span class="sw-launcher__text"></span>
</div>

{% comment %} ── Backdrop ── {% endcomment %}
<div id="sw-backdrop" class="sw-backdrop" aria-hidden="true"></div>

{% comment %} ── Modal ── {% endcomment %}
<div
  id="sw-modal"
  class="sw-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Spin the wheel to win a discount"
  hidden
>
  {% comment %} Close / cancel button {% endcomment %}
  <button class="sw-close" id="sw-close" type="button" aria-label="Close spin wheel">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5"
         stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6"  x2="6"  y2="18"/>
      <line x1="6"  y1="6"  x2="18" y2="18"/>
    </svg>
  </button>

  <div class="sw-modal__inner">

    {% comment %} ── Floating heart emojis (decorative background) ── {% endcomment %}
    <div class="sw-hearts" aria-hidden="true">
      <span class="sw-heart sw-heart--1">🩷</span>
      <span class="sw-heart sw-heart--2">💜</span>
      <span class="sw-heart sw-heart--3">🩷</span>
      <span class="sw-heart sw-heart--4">💜</span>
      <span class="sw-heart sw-heart--5">🩷</span>
      <span class="sw-heart sw-heart--6">💜</span>
      <span class="sw-heart sw-heart--7">🩷</span>
      <span class="sw-heart sw-heart--8">💜</span>
    </div>

    {% comment %} ── Left: copy & result ── {% endcomment %}
    <div class="sw-copy">
      {% comment %} <p class="sw-copy__eyebrow">Exclusive offer</p> {% endcomment %}
      <h2 class="sw-copy__heading">{{ sw_heading }}</h2>
      <p class="sw-copy__sub">{{ sw_subtext }}</p>

      {% comment %} Result card (hidden until win) {% endcomment %}
      <div class="sw-result" id="sw-result" hidden>
        <p class="sw-result__label">You won</p>
        <p class="sw-result__prize" id="sw-prize"></p>
        <div class="sw-result__codebox">
          <span class="sw-result__code" id="sw-code"></span>
          <button class="sw-result__copybtn" id="sw-copybtn" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <span id="sw-copylabel">Copy</span>
          </button>
        </div>
      </div>

      <button class="sw-spinbtn" id="sw-spinbtn" type="button">
        {{ sw_btn_label }}
      </button>
      <p class="sw-note" id="sw-note">Try your luck!</p>
    </div>

    {% comment %} ── Right: wheel ── {% endcomment %}
    <div class="sw-wheel-wrap">
      <div class="sw-pointer" aria-hidden="true"></div>
      <canvas id="sw-canvas" class="sw-canvas" width="320" height="320"></canvas>
      <div class="sw-cap" aria-hidden="true">✦</div>
    </div>

  </div>
</div>

{%- comment -%} ══════════════ STYLES ══════════════ {%- endcomment -%}
<style>
  /* ── Design tokens ── */
  :root {
    --sw-white:      #ffffff;
    --sw-bg:         #fffcf8;
    --sw-surface:    #ffffff;
    --sw-border:     #ede8f8;
    --sw-text:       #1a1523;
    --sw-muted:      #7a7087;
    --sw-accent:     #666d6b;       /*  — CTA * #FFC1CC/
    --sw-accent-lt:  #e8d5f5;      /* lavender tint */
    --sw-blush:      #fcd5ce;
    --sw-mint:       #c8f0e0;
    --sw-peach:      #fde8c8;
    --sw-sky:        #d4edfb;
    --sw-font-head:  'Playfair Display', Georgia, serif;
    --sw-font-body:  'DM Sans', system-ui, sans-serif;
    --sw-ease:       cubic-bezier(.4,0,.2,1);
  }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap');

  /* ── Launcher tab ── */
  .sw-launcher {
    position:    fixed;
    left:        0;
    top:         50%;
    transform:   translateY(-50%) translateX(-2px);
    z-index:     9998;
    display:     flex;
    align-items: center;
    gap:         8px;
    background:  var(--sw-accent);
    color:       #fff;
    padding:     14px 16px 14px 14px;
    border-radius: 0 40px 40px 0;
    cursor:      pointer;
    font-family: var(--sw-font-body);
    font-weight: 600;
    font-size:   .85rem;
    letter-spacing: .03em;
    box-shadow:  4px 0 24px rgba(196, 63, 63, 0.35);
    transition:  transform .3s var(--sw-ease),
                 box-shadow .3s var(--sw-ease);
    user-select: none;
    /* entrance animation */
    animation:   swTabIn .6s var(--sw-ease) .8s both;
  }
  @keyframes swTabIn {
    from { transform: translateY(-50%) translateX(-110%); }
    to   { transform: translateY(-50%) translateX(-2px); }
  }
  .sw-launcher:hover,
  .sw-launcher:focus-visible {
    transform:  translateY(-50%) translateX(0);
    box-shadow: 6px 0 32px #FDE2E4;
    outline:    none;
  }
  .sw-launcher.sw-launcher--hidden {
    display: none;
  }
  .sw-launcher__icon { font-size: 1.3rem; line-height: 1; }

  /* ── Backdrop ── */
  .sw-backdrop {
    display:    none;
    position:   fixed;
    inset:      0;
    z-index:    9999;
    background: rgba(26,21,35,.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity:    0;
    transition: opacity .35s var(--sw-ease);
  }
  .sw-backdrop.sw-backdrop--visible {
    display: block;
    opacity: 1;
  }

  /* ── Modal ── */
  .sw-modal {
    position:      fixed;
    inset:         0;
    z-index:       10000;
    display:       flex;
    align-items:   center;
    justify-content: center;
    padding:       16px;
    pointer-events: none;
    opacity:       0;
    transform:     scale(.94) translateY(16px);
    transition:    opacity .35s var(--sw-ease),
                   transform .35s var(--sw-ease);
  }
  .sw-modal.sw-modal--open {
    pointer-events: auto;
    opacity:        1;
    transform:      scale(1) translateY(0);
  }

  /* ── Modal inner card ── */
  .sw-modal__inner {
    position:        relative;
    background:      var(--sw-bg);
    border-radius:   28px;
    box-shadow:      0 32px 80px rgba(26,21,35,.22),
                     0 0 0 1px rgba(255,255,255,.8) inset;
    padding:         48px 40px 48px 44px;
    display:         flex;
    align-items:     center;
    gap:             52px;
    max-width:       820px;
    width:           100%;
    /* soft lavender top-left blob */
    overflow:        hidden;
  }
  .sw-modal__inner::before {
    content:         '';
    position:        absolute;
    top:  -120px; left: -100px;
    width:  340px; height: 340px;
    background:      var(--sw-accent-lt);
    border-radius:   50%;
    filter:          blur(80px);
    opacity:         .55;
    pointer-events:  none;
  }
  .sw-modal__inner::after {
    content:         '';
    position:        absolute;
    bottom: -100px; right: -80px;
    width:  280px; height: 280px;
    background:      var(--sw-blush);
    border-radius:   50%;
    filter:          blur(70px);
    opacity:         .45;
    pointer-events:  none;
  }

  /* ── Close button ── */
  .sw-close {
    position:    absolute;
    top:         16px;
    right:       16px;
    z-index:     10;
    width:       36px; height: 36px;
    display:     flex;
    align-items: center;
    justify-content: center;
    background:  var(--sw-border);
    border:      none;
    border-radius: 50%;
    cursor:      pointer;
    color:       var(--sw-muted);
    transition:  background .2s, color .2s, transform .2s;
  }
  .sw-close:hover {
    background: #e2d5f8;
    color:      var(--sw-accent);
    transform:  rotate(90deg);
  }
  .sw-close:focus-visible {
    outline: 2px solid var(--sw-accent);
    outline-offset: 2px;
  }

  /* ── Copy / left column ── */
  .sw-copy {
    flex:     1 1 240px;
    position: relative;
    z-index:  1;
  }
  .sw-copy__eyebrow {
    font-family:    var(--sw-font-body);
    font-size:      .75rem;
    font-weight:    600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color:          var(--sw-accent);
    margin:         0 0 8px;
  }
  .sw-copy__heading {
    font-family: var(--sw-font-head);
    font-size:   clamp(1.7rem, 3vw, 2.2rem);
    line-height: 1.15;
    color:       var(--sw-text);
    margin:      0 0 10px;
  }
  .sw-copy__sub {
    font-family: var(--sw-font-body);
    font-size:   .9rem;
    color:       var(--sw-muted);
    line-height: 1.6;
    margin:      0 0 28px;
  }

  /* ── Spin button ── */
  .sw-spinbtn {
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    background:      #FFC1CC;
    /* background:      var(--sw-accent); */
    /* color:           #fff; */
    color:           var(--sw-text);
    border:          none;
    border-radius:   50px;
    padding:         13px 40px;
    font-family:     var(--sw-font-body);
    font-size:       .95rem;
    font-weight:     700;
    letter-spacing:  .06em;
    text-transform:  uppercase;
    cursor:          pointer;
    box-shadow:      0 6px 24px rgba(92,63,196,.35);
    transition:      transform .2s, box-shadow .2s, background .2s;
    margin-bottom:   12px;
  }
  .sw-spinbtn:hover:not(:disabled) {
    background:  #4a30a8;
    transform:   translateY(-2px);
    box-shadow:  0 10px 32px rgba(92,63,196,.45);
  }
  .sw-spinbtn:disabled { opacity: .5; cursor: not-allowed; }

  /* ── Note ── */
  .sw-note {
    font-size:  .8rem;
    color:      var(--sw-muted);
    margin:     0;
    font-family: var(--sw-font-body);
  }

  /* ── Result card ── */
  .sw-result {
    background:    var(--sw-surface);
    border:        1.5px solid var(--sw-border);
    border-radius: 16px;
    padding:       20px 22px;
    margin-bottom: 20px;
    box-shadow:    0 4px 20px rgba(92,63,196,.08);
    animation:     swFadeUp .4s var(--sw-ease) both;
  }
  @keyframes swFadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sw-result__label {
    font-size:  .8rem;
    color:      var(--sw-muted);
    margin:     0 0 4px;
    font-family: var(--sw-font-body);
  }
  .sw-result__prize {
    font-family: var(--sw-font-head);
    font-size:   1.35rem;
    color:       var(--sw-text);
    margin:      0 0 14px;
  }
  .sw-result__codebox {
    display:       flex;
    align-items:   center;
    gap:           8px;
    background:    #f3eeff;
    border:        1.5px dashed var(--sw-accent-lt);
    border-radius: 10px;
    padding:       10px 14px;
  }
  .sw-result__code {
    font-family:    'Courier New', monospace;
    font-size:      1.05rem;
    font-weight:    700;
    letter-spacing: .1em;
    color:          var(--sw-accent);
    flex:           1;
  }
  .sw-result__copybtn {
    display:     inline-flex;
    align-items: center;
    gap:         5px;
    background:  var(--sw-accent);
    color:       #fff;
    border:      none;
    border-radius: 8px;
    padding:     7px 13px;
    font-family: var(--sw-font-body);
    font-size:   .78rem;
    font-weight: 600;
    cursor:      pointer;
    transition:  background .2s, transform .2s;
    white-space: nowrap;
  }
  .sw-result__copybtn:hover  { background: #4a30a8; transform: scale(1.04); }
  .sw-result__copybtn.copied { background: #2d9e5f; }

  /* ── Wheel wrap ── */
  .sw-wheel-wrap {
    position:  relative;
    flex:      0 0 auto;
    width:     min(320px, 80vw);
    height:    min(320px, 80vw);
    z-index:   1;
  }
  .sw-canvas {
    width:         100%;
    height:        100%;
    border-radius: 50%;
    display:       block;
    box-shadow:
      0 0 0 7px #fff,
      0 0 0 9px var(--sw-border),
      0 16px 48px rgba(92,63,196,.2);
  }

  /* ── Pointer arrow ── */
  .sw-pointer {
    position:     absolute;
    top:          -16px;
    left:         50%;
    transform:    translateX(-50%);
    z-index:      5;
    width:        0; height: 0;
    border-left:  11px solid transparent;
    border-right: 11px solid transparent;
    border-top:   22px solid var(--sw-accent);
    filter:       drop-shadow(0 3px 5px rgba(92,63,196,.4));
  }

  /* ── Centre cap ── */
  .sw-cap {
    position:     absolute;
    top:          50%; left: 50%;
    transform:    translate(-50%, -50%);
    z-index:      5;
    width:        36px; height: 36px;
    background:   #fff;
    border-radius: 50%;
    border:       2px solid var(--sw-border);
    display:      flex;
    align-items:  center;
    justify-content: center;
    font-size:    1rem;
    pointer-events: none;
    box-shadow:   0 2px 8px rgba(0,0,0,.08);
  }

  /* ── Static hearts ── */
  .sw-hearts {
    position:       absolute;
    inset:          0;
    pointer-events: none;
    z-index:        0;
    border-radius:  28px;
  }
  .sw-heart {
    position:   absolute;
    font-size:  1.1rem;
    opacity:    .28;
    user-select: none;
  }
  .sw-heart--1 { top: 8%;  left: 7%;  font-size: 1rem;   transform: rotate(-10deg); }
  .sw-heart--2 { top: 14%; left: 24%; font-size: 1.25rem; transform: rotate(8deg); }
  .sw-heart--3 { top: 10%; right: 18%; font-size: .95rem; transform: rotate(-6deg); }
  .sw-heart--4 { top: 28%; right: 8%; font-size: 1.2rem; transform: rotate(10deg); }
  .sw-heart--5 { bottom: 26%; left: 10%; font-size: 1rem; transform: rotate(-8deg); }
  .sw-heart--6 { bottom: 16%; left: 30%; font-size: 1.35rem; transform: rotate(12deg); }
  .sw-heart--7 { bottom: 12%; right: 24%; font-size: .9rem; transform: rotate(-12deg); }
  .sw-heart--8 { bottom: 22%; right: 9%; font-size: 1.1rem; transform: rotate(7deg); }


  @media (max-width: 640px) {
    .sw-modal__inner {
      flex-direction: column-reverse;
      padding:        36px 24px 32px;
      gap:            32px;
    }
    .sw-copy { text-align: center; }
    .sw-result__codebox { flex-direction: column; align-items: stretch; text-align: center; }
    .sw-launcher__text { display: none; }
    .sw-launcher { padding: 14px 12px; border-radius: 0 32px 32px 0; }
  }
</style>

{%- comment -%} ══════════════ JAVASCRIPT ══════════════ {%- endcomment -%}
<script>
(function () {
  'use strict';

  /* ─────────────────────────────────────────────
     SEGMENT DATA
     Edit labels, codes, and colors freely.
     Supported CSS colors: hex, rgb, hsl.
     You can have between 2 and 12 entries.
  ───────────────────────────────────────────── */
  var SEGMENTS = [
    { label: '15% OFF',    code: 'SPIN15',   color: '#E3F2FD' },
    { label: 'Free Potli',  code: 'FREESHIP', color: '#FFF4CC' },
    { label: 'Summer T Shirt',    code: 'SPIN15',   color: '#d4f1f4' },
    { label: 'Free Earrings',  code: 'TRYAGAIN', color: '#fde8c8' },
    { label: 'Best Mom Hoop',    code: 'SPIN-HOOP',   color: '#c8f0e0' },
    { label: '5% OFF',     code: 'SPIN5',    color: '#fce4ec' },
    { label: 'Free Scarf',  code: 'GIFTWRAP', color: '#dceefb' },
    { label: 'Try Again ',  code: 'LUCKY',    color: '#FDE2E4' }
  ];

  /* ─────────────────────────────────────────────
     KEYS — scoped so multiple pages don't clash
  ───────────────────────────────────────────── */
  var KEY_DISMISSED = 'sw_dismissed_v1';
  var KEY_PLAYED    = 'sw_played_v1';

  /* ── DOM refs ── */
  var launcher  = document.getElementById('sw-launcher');
  var backdrop  = document.getElementById('sw-backdrop');
  var modal     = document.getElementById('sw-modal');
  var closeBtn  = document.getElementById('sw-close');
  var canvas    = document.getElementById('sw-canvas');
  var spinBtn   = document.getElementById('sw-spinbtn');
  var resultBox = document.getElementById('sw-result');
  var prizeEl   = document.getElementById('sw-prize');
  var codeEl    = document.getElementById('sw-code');
  var copyBtn   = document.getElementById('sw-copybtn');
  var copyLabel = document.getElementById('sw-copylabel');
  var noteEl    = document.getElementById('sw-note');

  if (!canvas || !launcher) return;

  var ctx       = canvas.getContext('2d');
  var numSeg    = SEGMENTS.length;
  var arc       = (2 * Math.PI) / numSeg;
  var currentRot = -Math.PI / 2;  /* start so first segment is at top */
  var spinning  = false;

  /* ═══════════ WHEEL DRAWING ═══════════ */
  function drawWheel(rot) {
    var size = canvas.width;
    var cx = size / 2, cy = size / 2, r = cx - 3;

    ctx.clearRect(0, 0, size, size);

    for (var i = 0; i < numSeg; i++) {
      var start = rot + i * arc;
      var end   = start + arc;
      var seg   = SEGMENTS[i];

      /* Slice */
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, start, end);
      ctx.closePath();
      ctx.fillStyle = seg.color;
      ctx.fill();

      /* Border */
      ctx.strokeStyle = 'rgba(255,255,255,0.6)';
      ctx.lineWidth   = 2;
      ctx.stroke();

      /* Label */
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(start + arc / 2);
      ctx.textAlign    = 'right';
      ctx.font         = 'bold ' + fontSize(seg.label) + 'px "DM Sans",sans-serif';
      ctx.fillStyle    = textColor(seg.color);
      ctx.shadowColor  = 'rgba(0,0,0,.1)';
      ctx.shadowBlur   = 2;
      ctx.fillText(trimText(seg.label), r - 14, 5);
      ctx.restore();
    }
  }

  function fontSize(text) {
    var base = numSeg <= 6 ? 13 : numSeg <= 8 ? 11 : 9;
    if (text && text.length > 10) base = Math.max(base - 1, 8);
    return base;
  }
  function trimText(t) {
    var max = numSeg > 8 ? 9 : 14;
    return t && t.length > max ? t.slice(0, max - 1) + '…' : t;
  }
  function textColor(hex) {
    hex = hex.replace('#','');
    var r = parseInt(hex.slice(0,2),16),
        g = parseInt(hex.slice(2,4),16),
        b = parseInt(hex.slice(4,6),16);
    return (0.299*r + 0.587*g + 0.114*b)/255 > 0.6 ? '#2a1f4a' : '#fff';
  }

  /* ═══════════ SPIN LOGIC ═══════════ */
  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  function spin() {
    if (spinning) return;
    if (sessionStorage.getItem(KEY_PLAYED)) {
      noteEl.textContent = "You've already had your spin!";
      return;
    }

    /* ── Pick winner — only allowed labels can win ── */
    var WINNING_LABELS = ['Best Mom Hoop', '15% OFF'];

    /* Build an array of indexes whose label is in the allowed list */
    var winPool = [];
    for (var s = 0; s < numSeg; s++) {
      if (WINNING_LABELS.indexOf(SEGMENTS[s].label) !== -1) {
        winPool.push(s);
      }
    }

    /* Safety fallback: if no winning segments are found, pick any */
    var winIdx = winPool.length > 0
      ? winPool[Math.floor(Math.random() * winPool.length)]
      : Math.floor(Math.random() * numSeg);

    /*
      We need the center of slice `winIdx` to sit exactly at the pointer
      (top of wheel, angle = -π/2).

      Center of winning slice (from angle 0) = (winIdx + 0.5) * arc
      We want:  currentRot_final + (winIdx + 0.5) * arc  ≡  -π/2  (mod 2π)
      So:       delta = -π/2 - (winIdx + 0.5) * arc - currentRot
      Then add extra full spins to make it dramatic.
    */
    var targetCenter = -Math.PI / 2 - (winIdx + 0.5) * arc;
    var extraSpins   = (5 + Math.floor(Math.random() * 4)) * 2 * Math.PI;
    var delta        = targetCenter - currentRot;

    /* Normalise delta into (0, 2π] so we always spin forward */
    delta = ((delta % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
    if (delta === 0) delta = 2 * Math.PI;

    var totalRot  = extraSpins + delta;
    var duration  = 4500 + Math.random() * 1000;
    var startTime = null;
    var startRot  = currentRot;

    spinning = true;
    spinBtn.disabled = true;
    resultBox.hidden = true;
    noteEl.textContent = 'Spinning…';

    function frame(ts) {
      if (!startTime) startTime = ts;
      var progress  = Math.min((ts - startTime) / duration, 1);
      var eased     = easeOut(progress);

      currentRot = startRot + totalRot * eased;
      drawWheel(currentRot);

      if (progress < 1) {
        requestAnimationFrame(frame);
      } else {
        currentRot = startRot + totalRot;
        drawWheel(currentRot);
        spinning = false;

        sessionStorage.setItem(KEY_PLAYED, '1');

        /* Hide launcher only after a spin — not on cancel */
        sessionStorage.setItem(KEY_DISMISSED, '1');
        launcher.classList.add('sw-launcher--hidden');

        var winner      = SEGMENTS[winIdx];
        prizeEl.textContent = winner.label;
        codeEl.textContent  = winner.code;
        resultBox.hidden    = false;
        noteEl.textContent  = "Your code is ready — use it at checkout!";
      }
    }
    requestAnimationFrame(frame);
  }

  /* ═══════════ COPY CODE ═══════════ */
  function copyCode() {
    var code = codeEl.textContent.trim();
    if (!code) return;

    function onCopied() {
      copyLabel.textContent = '✓ Copied';
      copyBtn.classList.add('copied');
      setTimeout(function() {
        copyLabel.textContent = 'Copy';
        copyBtn.classList.remove('copied');
      }, 2200);
    }

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(onCopied).catch(fallback);
    } else { fallback(); }

    function fallback() {
      var ta = document.createElement('textarea');
      ta.value = code;
      ta.style.cssText = 'position:fixed;left:-9999px;top:-9999px';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); onCopied(); } catch(e){}
      document.body.removeChild(ta);
    }
  }

  /* ═══════════ OPEN / CLOSE ═══════════ */
  function openModal() {
    modal.removeAttribute('hidden');
    backdrop.classList.add('sw-backdrop--visible');
    /* Tiny rAF so the hidden→block transition has time to paint before opacity animates */
    requestAnimationFrame(function() {
      modal.classList.add('sw-modal--open');
    });
    document.body.style.overflow = 'hidden';
    modal.focus && modal.focus();
  }

  function closeModal() {
    modal.classList.remove('sw-modal--open');
    backdrop.classList.remove('sw-backdrop--visible');
    document.body.style.overflow = '';

    /* After animation, just hide the modal — launcher stays visible */
    setTimeout(function() {
      modal.setAttribute('hidden', '');
    }, 380);
  }

  /* Trap focus inside modal for a11y */
  modal.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });

  /* Click outside modal card closes it */
  backdrop.addEventListener('click', closeModal);

  /* ── Wire up ── */
  launcher.addEventListener('click', openModal);
  launcher.addEventListener('keydown', function(e){
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(); }
  });
  closeBtn.addEventListener('click', closeModal);
  spinBtn.addEventListener('click', spin);
  copyBtn.addEventListener('click', copyCode);

  /* ═══════════ INIT ═══════════ */
  drawWheel(currentRot);

  /* If already spun this session — disable button and hide launcher */
  if (sessionStorage.getItem(KEY_PLAYED)) {
    spinBtn.disabled   = true;
    noteEl.textContent = "You've already had your spin this visit!";
    /* Launcher hides because a spin was completed, not because of cancel */
    launcher.classList.add('sw-launcher--hidden');
  }

})();
</script>
